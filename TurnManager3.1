using UnityEngine;

public class TurnManager
{
    private int m_TurnCount;
    public event System.Action OnTick;
    public TurnManager()
    {
        m_TurnCount = 1;
    }

    // 必须是 public 公开方法，外部才能调用
    public void Tick()
    {
        OnTick?.Invoke();
        m_TurnCount += 1;
        Debug.Log("Current turn count : " + m_TurnCount);
    }
}
